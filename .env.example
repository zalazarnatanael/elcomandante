# ============================================================================
# OpenClaw - Multi-Project Notion → GitHub → PR Automation Bot
# Environment Variables Example
# ============================================================================
# IMPORTANT: Copy this to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================================

# ============================================================================
# 1. DATABASE CONNECTION (Postgres)
# ============================================================================
DATABASE_URL=postgres://user:password@host:5432/db

# ============================================================================
# 1b. SUPABASE AUTH (JWT)
# ============================================================================
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============================================================================
# 2. ENCRYPTION (Local AES-256, MASTER_KEY stored in ENV ONLY)
# ============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your-32-byte-hex-key-here

# ============================================================================
# 3. GITHUB CONFIGURATION
# ============================================================================
GITHUB_TOKEN=ghp_your-personal-access-token-here
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# OPTIONAL: Default fallback GitHub user for commits if no assignee
# (We currently block execution when there is no assignee.)
# DEFAULT_GITHUB_ASSIGNEE=

# ============================================================================
# 4. NOTION CONFIGURATION (Multi-workspace support)
# ============================================================================
# NOTE: Notion API keys are now stored encrypted in Supabase table notion_workspaces
# See: services/notionCredentialsManager.js
# 
# To manage Notion workspaces, use:
#   node scripts/manage-notion-workspace.js add --workspace-id ws-1 --name "Main" --api-key "ntn_xxxxx"
#   node scripts/manage-notion-workspace.js link-project --project-id proyecto-1 --workspace-id ws-1
#   node scripts/manage-notion-workspace.js list
#   node scripts/manage-notion-workspace.js validate --workspace-id ws-1
#
# YOU NO LONGER NEED TO SET NOTION_API_KEY HERE
# (Credentials are now managed dynamically and encrypted in Supabase)

# ============================================================================
# 5. OPENAI / LLM CONFIGURATION (for complexity detection & planning)
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL_SIMPLE=gpt-4o-mini
OPENAI_MODEL_MEDIUM=gpt-4o
OPENAI_MODEL_COMPLEX=gpt-4-turbo

# ============================================================================
# 6. REDIS CONFIGURATION (for caching & task queuing)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# 7. TELEGRAM NOTIFICATIONS (Optional)
# ============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ============================================================================
# 8. SERVER & WEBHOOK CONFIGURATION
# ============================================================================
PORT=3001
WEBHOOK_URL=https://your-domain.com/webhook
NODE_ENV=development

# 8b. AUTH
# Supabase JWTs from frontend (Authorization: Bearer <token>) are required for non-webhook routes
# Optional: set role in app_metadata.role for admin access

# Roles example: admin, viewer

# Swagger
# Docs available at /docs

# ============================================================================
# 9. LOGGING & DEBUG
# ============================================================================
LOG_LEVEL=info
DEBUG=false

API_BASE_URL=http://localhost:8000/api

# ============================================================================
# 10. PROJECT-SPECIFIC CONFIGURATION
# ============================================================================
# These are loaded from config/projects.js
# Example projects (see config/projects.js for full configuration):
#
# PROJECT_1=v0-ferreteria
# PROJECT_1_GITHUB_ORG=your-org
# PROJECT_1_GITHUB_REPO=your-repo
# PROJECT_1_NOTION_DB=your-notion-database-id
#
# PROJECT_2=v1-ecommerce
# PROJECT_2_GITHUB_ORG=your-org
# PROJECT_2_GITHUB_REPO=your-repo
# PROJECT_2_NOTION_DB=your-notion-database-id
#
# ... (up to 4 projects)

# ============================================================================
# NOTES
# ============================================================================
# 1. MASTER_KEY: Generate a secure 32-byte hex key
#    $ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. GITHUB_TOKEN: Personal access token with repo & workflow permissions
#    https://github.com/settings/tokens
#
# 3. NOTION_WORKSPACES: Create an integration at https://www.notion.so/my-integrations
#    Then register it with:
#    $ node scripts/manage-notion-workspace.js add --workspace-id ws-1 --name "..." --api-key "ntn_xxxxx"
#    Link to projects with:
#    $ node scripts/manage-notion-workspace.js link-project --project-id proyecto-1 --workspace-id ws-1

# 3b. DEVELOPER CREDENTIALS: Store per-developer GitHub tokens encrypted
#    $ node scripts/manage-developers.js add --github-username <user> --token "ghp_xxxxx"
#    $ node scripts/manage-developers.js list
#    $ node scripts/manage-developers.js validate --github-username <user>
#
# 4. OPENAI_API_KEY: Get from https://platform.openai.com/api-keys
#
# 5. SUPABASE: Create a project at https://app.supabase.com
#    Run migrations from db/schema.sql after setup
#
# 6. REDIS: Required for task caching. Local dev: redis-server
#    Production: Use managed Redis (e.g., Redis Cloud, AWS ElastiCache)
#
# 7. TELEGRAM_BOT_TOKEN: Create a bot with @BotFather on Telegram
#    Get CHAT_ID from: https://api.telegram.org/bot{TOKEN}/getUpdates
#
# 8. For production, use environment variables from your hosting provider
#    (e.g., Vercel, Railway, Render, Heroku) instead of .env file
